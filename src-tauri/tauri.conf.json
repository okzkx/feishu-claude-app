{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "feishu-claude-app",
  "version": "0.1.0",
  "identifier": "com.feishu.claude.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "飞书 Claude 消息轮询",
        "width": 900,
